{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard.cjs\"",
            "timeout": 10,
            "statusMessage": "危険操作ガードを確認中..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/skill-log.cjs\"",
            "async": true,
            "timeout": 10,
            "statusMessage": "skill 使用を記録中..."
          }
        ]
      }
    ]
  }
}
